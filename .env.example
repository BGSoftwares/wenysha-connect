# Environment Variables for Wenyasha Connect

# Django Backend API URL
# Set this to your Django server URL when running locally or in production
VITE_API_URL=http://127.0.0.1:8000

# WebSocket URL (optional - auto-derived from API URL if not set)
# VITE_WS_URL=ws://127.0.0.1:8000/ws/notifications/

# For production deployment, update these:
# VITE_API_URL=https://your-backend-domain.com
# VITE_WS_URL=wss://your-backend-domain.com/ws/notifications/
