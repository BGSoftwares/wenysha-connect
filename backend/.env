# Django / MySQL / JWT / CORS config
DJANGO_SECRET_KEY=dev-secret-change-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Add your ngrok domain (without https://)
NGROK_DOMAIN=katia-serpentiform-humiliatingly.ngrok-free.dev
# Add your preview domain (without https://) - e.g., your-project.lovable.app
PREVIEW_DOMAIN=

# MySQL connection used by Django
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=wenysha_connect
MYSQL_USER=root
MYSQL_PASSWORD=

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080,http://localhost:8081

# JWT lifetimes
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# Admin user to create by seed script
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_EMAIL=admin@wenysha.com
SEED_ADMIN_PASSWORD=adminpass

# Database Choice
USE_SQLITE=True
