+from django.db.models.signals import post_save
+from django.dispatch import receiver
+from asgiref.sync import async_to_sync
+from channels.layers import get_channel_layer
+
+from .models import Invoice, Payment
+
+channel_layer = get_channel_layer()
+
+def broadcast_notification(payload: dict):
+    async_to_sync(channel_layer.group_send)(
+        "notifications",
+        {"type": "notify.message", "payload": payload}
+    )
+
+@receiver(post_save, sender=Payment)
+def payment_created(sender, instance, created, **kwargs):
+    if created:
+        payload = {
+            "event": "payment_created",
+            "id": instance.id,
+            "amount": str(instance.amount),
+            "invoice_id": instance.invoice.id if getattr(instance, "invoice", None) else None,
+        }
+        broadcast_notification(payload)
+
+@receiver(post_save, sender=Invoice)
+def invoice_saved(sender, instance, created, **kwargs):
+    payload = {
+        "event": "invoice_created" if created else "invoice_updated",
+        "id": instance.id,
+        "invoice_number": getattr(instance, "invoice_number", None),
+        "status": getattr(instance, "status", None),
+    }
+    broadcast_notification(payload)
