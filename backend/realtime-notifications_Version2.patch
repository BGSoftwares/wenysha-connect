+        ) : (
+          <ul className="space-y-2">
+            {messages.map((m, idx) => {
+              const payload = (m && m.payload) ? m.payload : m;
+              return (
+                <li key={idx} className="p-2 border rounded bg-muted/50">
+                  <pre className="text-xs">{JSON.stringify(payload, null, 2)}</pre>
+                </li>
+              );
+            })}
+          </ul>
+        )}
+      </div>
+    </div>
+  );
+};
+
+export default Notifications;
