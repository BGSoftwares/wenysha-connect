+const makeWsUrl = () => {
+  const explicit = import.meta.env.VITE_WS_URL;
+  if (explicit) return explicit;
+  const api = (import.meta.env.VITE_API_URL ?? "http://127.0.0.1:8000").replace(/\/+$/, "");
+  return api.replace(/^http/, "ws") + "/ws/notifications/";
+};
+
+export const WS_URL = makeWsUrl();
+
+export function createWebSocket(onOpen?: () => void, onMessage?: (data: any) => void, onClose?: () => void) {
+  const url = WS_URL;
+  const ws = new WebSocket(url);
+
+  ws.onopen = () => onOpen?.();
+
+  ws.onmessage = (ev) => {
+    let payload;
+    try { payload = JSON.parse(ev.data); } catch { payload = ev.data; }
+    onMessage?.(payload);
+  };
+
+  ws.onclose = () => onClose?.();
+
+  ws.onerror = (err) => { console.error("WebSocket error", err); };
+
+  return ws;
+}
+
