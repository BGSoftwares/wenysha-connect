+import { useEffect, useRef, useState } from "react";
+import { createWebSocket } from "@/lib/ws";
+
+export function useWebSocket() {
+  const wsRef = useRef<WebSocket | null>(null);
+  const [connected, setConnected] = useState(false);
+  const [messages, setMessages] = useState<any[]>([]);
+
+  useEffect(() => {
+    let reconnectTimer: any = null;
+    let shouldUnmount = false;
+
+    const connect = () => {
+      const ws = createWebSocket(
+        () => setConnected(true),
+        (message) => setMessages(prev => [message, ...prev].slice(0, 50)),
+        () => {
+          setConnected(false);
+          if (!shouldUnmount) reconnectTimer = setTimeout(connect, 2000);
+        }
+      );
+      wsRef.current = ws;
+    };
+
+    connect();
+
+    return () => {
+      shouldUnmount = true;
+      if (reconnectTimer) clearTimeout(reconnectTimer);
+      if (wsRef.current) wsRef.current.close();
+    };
+  }, []);
+
+  const send = (obj: any) => {
+    try { wsRef.current?.send(JSON.stringify(obj)); }
+    catch (e) { console.warn("WebSocket send failed", e); }
+  };
+
+  return { connected, messages, send };
+}
+
